# Backend environment variables

# Flask
FLASK_ENV=development
DEBUG=False

# Server
API_HOST=127.0.0.1
API_PORT=5000
# Rate Limit 설정은 config.json의 "rate_limits" 섹션에서 관리합니다.
CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000,http://127.0.0.1,file://

# Logging
LOG_LEVEL=INFO
LOG_DIRECTORY=logs
LOG_FILE_PREFIX=monitoring_backend
LOG_RETENTION_DAYS=7
LOG_SLOW_QUERY_THRESHOLD_SEC=10

# JWT Security
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Login Credentials (change in production)
AUTH_USERNAME=admin
AUTH_PASSWORD=admin

# Database Connection Pool
DB_POOL_SIZE=5
DB_POOL_TIMEOUT_SEC=30
DB_POOL_RECYCLE_SEC=3600

# API Caching
CACHE_TTL_SEC=300
ENABLE_CACHE=true

# Thread Pool
THREAD_POOL_SIZE=16
