# Backend environment variables — example template.
#
# 운영/로깅/풀/캐시/스레드 등 대부분의 튜닝 항목은 settings DB
# (config 섹션) 에서 관리합니다. .env 는 "보안 키" + "환경 분기 /
# 부트스트랩 폴백" 만 담당합니다.

# ── Runtime ──────────────────────────────────────────────────────────────
FLASK_ENV=development
# USE_WAITRESS=1            # 0 → werkzeug 개발 서버, 1 → waitress (기본 1)
# WAITRESS_THREADS=16       # waitress 워커 스레드 수 (기본 16)

# ── CORS (production 권장 — 미설정 시 wildcard '*' + 경고) ───────────
# 쉼표 구분 allowlist. (옛 키 CORS_ORIGINS 도 backward-compat 로 인식되지만
# 신규 설정은 CORS_ALLOWED_ORIGINS 를 사용하세요.)
CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# ── JWT ──────────────────────────────────────────────────────────────────
# RFC 7518 §3.2 — HS256 키는 최소 32바이트. 미설정 시 안전한 기본값으로
# 폴백되지만 운영에서는 반드시 강한 무작위 값으로 교체하세요.
#   생성 예: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256

# ── Bootstrap admin ──────────────────────────────────────────────────────
# DB(monigrid_users) 에 admin 역할 계정이 하나도 없을 때만 동작하는
# 부트스트랩 폴백 로그인. admin 이 DB 에 1개라도 생기면 자동 비활성화됨.
# 운영 절차: 최초 기동 후 즉시 POST /admin/users 로 관리자 계정 생성 →
# 이후 AUTH_PASSWORD 는 비워두거나 랜덤값으로 덮어두는 것을 권장합니다.
AUTH_USERNAME=admin
AUTH_PASSWORD=admin

# ── DB 풀 ────────────────────────────────────────────────────────────────
DB_POOL_SIZE=5

# ── Notification subsystem master encryption key (Phase 6) ───────────────
# Used to encrypt SMTP password (and future channel secrets) before storing
# them in monigrid_notification_channels.config_encrypted.
#
# 형식 (둘 중 하나):
#   1) 32-byte urlsafe base64 Fernet key — 권장. 생성:
#        python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#   2) 임의 passphrase — 코드가 sha256 으로 32B 다이제스트 후 base64 변환.
#
# FLASK_ENV=development 인 경우만 미설정 시 deterministic dev fallback key
# 가 적용됩니다. production/staging 에서는 설정하지 않으면 BE 시작이 실패합니다.
MONIGRID_SECRET_KEY=

# 키 회전 시: MONIGRID_SECRET_KEYS 에 "신규,이전" CSV 로 양쪽 모두 설정.
# 첫 번째 키가 active 키(암호화에 사용), 나머지는 복호화 전용으로 사용됩니다.
# 모든 row 가 신규 키로 재암호화될 때까지(채널 save 시 자동) 이전 키를
# 유지하다가, 회전 완료 후 신규 키 단일 값으로 다시 정리합니다.
# MONIGRID_SECRET_KEYS 가 설정되면 MONIGRID_SECRET_KEY 는 무시됩니다.
# MONIGRID_SECRET_KEYS=

# ── Notification subsystem tunables (옵션 — 전부 default 사용 가능) ─────
# NOTIFICATION_POLL_SEC=30          # 워커 큐 폴링 주기 (초)
# NOTIFICATION_WORKERS=4            # 워커 ThreadPool 크기
# NOTIFICATION_BATCH=50             # 한 tick 에 처리할 큐 row 수
# NOTIFICATION_META_TICK_SEC=300    # dead 누적 메타-알람 체크 주기 (초)
# NOTIFICATION_META_WINDOW_SEC=86400 # 메타-알람 평가 윈도우 (초)
# NOTIFICATION_META_THRESHOLD=100   # 메타-알람 임계값
# MONIGRID_NOTIFICATION_FAULT=      # raise|hang|fail — 5중 격리 검증용 (dev 전용)
