# Backend environment variables

# Flask
FLASK_ENV=development
DEBUG=False

# Server
API_HOST=127.0.0.1
API_PORT=5000
# Rate Limit 설정은 config.json의 "rate_limits" 섹션에서 관리합니다.
CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000,http://127.0.0.1,file://

# Logging
LOG_LEVEL=INFO
LOG_DIRECTORY=logs
LOG_FILE_PREFIX=monitoring_backend
LOG_RETENTION_DAYS=7
LOG_SLOW_QUERY_THRESHOLD_SEC=10

# JWT Security
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Notification subsystem master encryption key (Phase 6).
# Used to encrypt SMTP password (and future channel secrets) before storing
# them in monigrid_notification_channels.config_encrypted.
#
# 형식 (둘 중 하나):
#   1) 32-byte urlsafe base64 Fernet key — 권장. 생성:
#        python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#   2) 임의 passphrase — 코드가 sha256 으로 32B 다이제스트 후 base64 변환.
#
# FLASK_ENV=development 인 경우만 미설정시 deterministic dev fallback key 가 적용됩니다.
# production/staging 에서는 설정하지 않으면 BE 시작이 실패합니다.
MONIGRID_SECRET_KEY=

# Notification subsystem tunables (옵션 — 전부 default 사용 가능)
# NOTIFICATION_POLL_SEC=30        # 워커 큐 폴링 주기 (초)
# NOTIFICATION_WORKERS=4          # 워커 ThreadPool 크기
# NOTIFICATION_BATCH=50           # 한 tick 에 처리할 큐 row 수
# NOTIFICATION_META_TICK_SEC=300  # dead 100/24h 메타-알람 체크 주기
# NOTIFICATION_META_THRESHOLD=100 # 메타-알람 임계값
# MONIGRID_NOTIFICATION_FAULT=    # raise|hang|fail — 5중 격리 검증용 (dev 전용)

# Login Credentials (change in production)
AUTH_USERNAME=admin
AUTH_PASSWORD=admin

# Database Connection Pool
DB_POOL_SIZE=5
DB_POOL_TIMEOUT_SEC=30
DB_POOL_RECYCLE_SEC=3600

# API Caching
CACHE_TTL_SEC=300
ENABLE_CACHE=true

# Thread Pool
THREAD_POOL_SIZE=16
