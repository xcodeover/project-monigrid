{
    "name": "monigrid-fe",
    "private": true,
    "version": "1.0.0",
    "description": "Monitoring dashboard desktop app",
    "type": "module",
    "main": "electron/main.cjs",
    "scripts": {
        "dev": "vite",
        "dev:web": "vite",
        "dev:simulation": "vite --mode simulation",
        "dev:electron": "cross-env ELECTRON_START_URL=http://127.0.0.1:3000 wait-on tcp:3000 && electron .",
        "dev:electron:simulation": "cross-env ELECTRON_START_URL=http://127.0.0.1:3000 wait-on tcp:3000 && electron .",
        "dev:desktop": "concurrently -k \"npm:dev:web\" \"npm:dev:electron\"",
        "dev:desktop:simulation": "concurrently -k \"npm:dev:simulation\" \"npm:dev:electron:simulation\"",
        "build": "vite build",
        "build:simulation": "vite build --mode simulation",
        "build:web": "vite build",
        "build:iis": "vite build --mode iis",
        "build:desktop": "npm run build:web && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win nsis",
        "pack:desktop": "npm run build:web && powershell -ExecutionPolicy Bypass -File electron/package-portable.ps1",
        "preview": "vite preview"
    },
    "dependencies": {
        "axios": "^1.6.0",
        "prismjs": "^1.30.0",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-grid-layout": "^2.2.2",
        "react-resizable": "^3.1.3",
        "react-router-dom": "^6.20.0",
        "react-simple-code-editor": "^0.14.1",
        "recharts": "^3.8.1",
        "zustand": "^4.4.0"
    },
    "devDependencies": {
        "@types/react": "^18.2.0",
        "@types/react-dom": "^18.2.0",
        "@vitejs/plugin-react": "^4.2.0",
        "autoprefixer": "^10.4.0",
        "concurrently": "^9.0.1",
        "cross-env": "^7.0.3",
        "electron": "^31.7.7",
        "electron-builder": "^26.8.1",
        "postcss": "^8.4.0",
        "tailwindcss": "^3.3.0",
        "vite": "^5.0.0",
        "wait-on": "^8.0.1"
    },
    "build": {
        "appId": "com.monigrid.dashboard",
        "productName": "monigrid-fe",
        "asar": true,
        "directories": {
            "output": "release"
        },
        "files": [
            "dist/**/*",
            "electron/**/*",
            "package.json"
        ],
        "forceCodeSigning": false,
        "toolsets": {
            "winCodeSign": "1.1.0"
        },
        "win": {
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "verifyUpdateCodeSignature": false,
            "signAndEditExecutable": false
        }
    }
}
